import random
import time
from datetime import datetime

warehouse = []

regions = ["North", "South", "East", "West"]

print("=== Real-Time Data Warehousing Started ===\n")

for i in range(15):

    new_data = {
        "region": random.choice(regions),
        "amount": random.randint(100, 1000),
        "time": datetime.now().strftime("%H:%M:%S")
    }

    warehouse.append(new_data)

    print("New Record Added →", new_data)

    total_sales = {}

    for record in warehouse:
        region = record["region"]

        if region in total_sales:
            total_sales[region] += record["amount"]
        else:
            total_sales[region] = record["amount"]

    print("Updated Total Sales Per Region:")
    for r, amt in total_sales.items():
        print(f"  {r} : {amt}")

    print("-" * 45)

    time.sleep(1)

print("\n=== Data Warehousing Process Completed ===")







CREATE DATABASE megamart_db;
USE megamart_db;

CREATE TABLE dim_customer (
    customer_id INT PRIMARY KEY,
    customer_name VARCHAR(100),
    email VARCHAR(100),
    updated_at DATETIME
);

CREATE TABLE stg_customer (
    customer_id INT,
    customer_name VARCHAR(100),
    email VARCHAR(100),
    updated_at DATETIME
);

