INSERT INTO dim_customer (customer_id, customer_name, email, updated_at)
SELECT s.customer_id, s.customer_name, s.email, s.updated_at
FROM stg_customer s
LEFT JOIN dim_customer d
ON s.customer_id = d.customer_id
WHERE d.customer_id IS NULL;

SELECT * FROM stg_customer;
SELECT * FROM dim_customer;

UPDATE dim_customer d
JOIN stg_customer s
ON d.customer_id = s.customer_id
SET d.customer_name = s.customer_name,
    d.email = s.email,
    d.updated_at = s.updated_at
WHERE s.updated_at > d.updated_at;

SELECT * FROM dim_customer;

SELECT * FROM dim_customer
WHERE updated_at > '2023-01-10';

SELECT COUNT(*) FROM dim_customer;

