#Practical 4: encoding dummification & scaling

# Install once
install.packages("readxl")
library(readxl)

# Load dataset
df <- read.csv("C:/Users/ADMIN/Downloads/Impact of Smartphone Usage on Mental Health .csv")
# Make a copy for label encoding
df_encoded <- df

# Label encode categorical columns
df_encoded[] <- lapply(df_encoded, function(col) {
  if (is.character(col) || is.factor(col)) {
    return(as.numeric(as.factor(col)))
  } else {
    return(col)
  }
})

head(df_encoded)



# Install once
install.packages("fastDummies")

library(fastDummies)

# Create dummy variables
df_dummy <- dummy_cols(
  df,
  remove_first_dummy = TRUE,       # Avoid dummy trap
  remove_selected_columns = TRUE   # Removes original categorical columns
)

head(df_dummy)



# Identify numeric columns
num_cols <- sapply(df_dummy, is.numeric)

# Scale numeric features
df_scaled <- df_dummy
df_scaled[num_cols] <- scale(df_dummy[num_cols])

head(df_scaled)


#Practical 5:hypothesis testing & anova

colnames(data)

data <- read.csv(file.choose(), stringsAsFactors = FALSE)

likert_map <- function(x) {
  x <- trimws(x)
  ifelse(x == "Never", 1,
         ifelse(x == "Rarely", 2,
                ifelse(x == "Sometimes", 3,
                       ifelse(x == "Often", 4,
                              ifelse(x == "Very Often", 5,
                                     ifelse(x == "Always", 5, NA))))))
}

data$sleep_disturb <- likert_map(
  data[["Does.your.phone.disturb.your.sleep.or.keep.you.awake..."]]
)

data$day_sleepy <- likert_map(
  data[["Do.you.feel.tired.or.sleepy.during.the.day.because.of.late.night.phone.use..."]]
)

valid_data <- na.omit(data[, c("sleep_disturb", "day_sleepy")])

one_sample_test <- t.test(valid_data$sleep_disturb, mu = 3)
one_sample_test

paired_test <- t.test(
  valid_data$sleep_disturb,
  valid_data$day_sleepy,
  paired = TRUE
)
paired_test


data <- read.csv("C:/Users/ADMIN/Downloads/Impact of Smartphone Usage on Mental Health .csv",
                 header = TRUE, stringsAsFactors = FALSE)

print(names(data))

names(data) <- make.names(names(data))
print(names(data))   # look at the new names


data$Smartphone_Usage <- factor(
  data$How.many.hours.do.you.use.your.phone.on.a.normal.day.,
  levels = c("1 - 3 hours", "3 - 5 hours", "5 - 7 hours", "More than 7 hours"),
  ordered = TRUE
)

data$Mental_Health_Score <- as.numeric(factor(
  data$Overall..do.you.feel.that.your.smartphone.use.is.affecting.your.mental.well.being.,
  levels = c("Not at all", "A little", "Sometimes", "Often", "Very often"),
  labels = c(1, 2, 3, 4, 5)
))

str(data)

one_way_aov <- aov(Mental_Health_Score ~ Smartphone_Usage, data = data)
summary(one_way_aov)

data$Gender <- as.factor(data$What.is.your.gender.)

two_way_aov <- aov(Mental_Health_Score ~ Smartphone_Usage * Gender, data = data)
summary(two_way_aov)

install.packages("AICcmodavg")
library(AICcmodavg)

model.set <- list(one_way_aov, two_way_aov)
model.names <- c("One_Way_ANOVA", "Two_Way_ANOVA")
aictab(model.set, modnames = model.names)

install.packages("ggplot2")
install.packages("gridExtra")
library(ggplot2)
library(gridExtra)

plot1 <- ggplot(data, aes(x = Smartphone_Usage,
                          y = Mental_Health_Score,
                          fill = Smartphone_Usage)) +
  geom_boxplot(alpha = 0.7) +
  theme_minimal() +
  labs(title = "One-Way ANOVA",
       x = "Smartphone Usage (Hours)",
       y = "Mental Health Score (1–5)")

plot2 <- ggplot(data, aes(x = Smartphone_Usage,
                          y = Mental_Health_Score,
                          fill = Gender)) +
  geom_boxplot(alpha = 0.7) +
  theme_minimal() +
  labs(title = "Two-Way ANOVA",
       x = "Smartphone Usage (Hours)",
       y = "Mental Health Score (1–5)")

grid.arrange(plot1, plot2, ncol = 2)


